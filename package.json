{
  "name": "nirvana-solana",
  "version": "0.1.0",
  "description": "TypeScript client library for Nirvana V2 and Samsara protocols on Solana",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/kit": "^6.5.0",
    "@solana-program/token": "^0.12.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/compute-budget": "^0.15.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
